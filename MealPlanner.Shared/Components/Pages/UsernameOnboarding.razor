@page "/onboarding/username"
@using MealPlanner.Shared.Services
@using MealPlanner.Shared.Models
@inject IJSRuntime JS
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app onboarding-container" dir="rtl">
    <div class="onboarding-card card-playful">
        <div class="logo-container">
            <span class="emoji-bounce">🍳</span>
            <span class="emoji-float emoji-delay-1">🥑</span>
            <span class="emoji-float emoji-delay-2">🍕</span>
            <span class="emoji-float emoji-delay-3">🍓</span>
        </div>
        <h1 class="playful-title">مرحباً بك في مخطط الوجبات! 🎉</h1>
        <p class="subtitle">طريقتك الممتعة لتنظيم وجباتك الأسبوعية مع عائلتك أو بمفردك.</p>
        
        <div class="form-group">
            <label for="username" class="playful-label">اختر اسم مستخدم مميزاً:</label>
            <input id="username" type="text" @bind="username" @bind:event="oninput" @onkeydown="HandleKeyDown" 
                   class="playful-input" placeholder="مثال: رامي، سارة، أحمد..." />
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <span class="error-msg text-danger mt-2 d-block">⚠️ @error</span>
            }
        </div>

        <button class="primary-btn btn-playful" @onclick="SubmitUsername" disabled="@string.IsNullOrWhiteSpace(username)">
            يلا نبدأ! 🚀
        </button>
    </div>
</div>

@code {
    private string username = "";
    private string error = "";

    private async Task SubmitUsername()
    {
        if (string.IsNullOrWhiteSpace(username)) return;

        username = username.Trim();
        if (username.Length < 2)
        {
            error = "اسم المستخدم قصير جداً (حرفين على الأقل).";
            return;
        }

        try 
        {
            error = "جاري التحقق...";
            StateHasChanged();
            
            // Check if username is already taken
            var profile = await UserService.GetProfileAsync(username);
            if (profile is not null)
            {
                error = "اسم المستخدم غير متاح";
                return;
            }

            // Create new profile (this will auto-create the solo household)
            var newProfile = new UserProfile
            {
                Username = username
            };
            await UserService.CreateProfileAsync(newProfile);

            // Save to local storage
            await JS.InvokeVoidAsync("localStorage.setItem", "username", username);
            UserService.ClearCachedHouseholdId(); // reset cache for new user

            error = "";
            Nav.NavigateTo("/onboarding/cuisines");
        }
        catch (Exception ex)
        {
            error = $"حدث خطأ ما: {ex.Message}";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitUsername();
        }
    }
}
