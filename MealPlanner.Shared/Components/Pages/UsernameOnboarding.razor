@page "/onboarding/username"
@using MealPlanner.Shared.Services
@using MealPlanner.Shared.Models
@inject IAuthService Auth
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app onboarding-container" dir="rtl">
    <div class="onboarding-card card-playful">
        <div class="logo-container">
            <span class="emoji-bounce">🍳</span>
            <span class="emoji-float emoji-delay-1">🥑</span>
            <span class="emoji-float emoji-delay-2">🍕</span>
            <span class="emoji-float emoji-delay-3">🍓</span>
        </div>
        <h1 class="playful-title">مرحباً بك في مخطط الوجبات! 🎉</h1>
        <p class="subtitle">طريقتك الممتعة لتنظيم وجباتك الأسبوعية مع عائلتك أو بمفردك.</p>

        @if (isChecking)
        {
            <p style="text-align:center; color:var(--color-text-secondary);">جارٍ التحقق...</p>
        }
        else
        {
            <div class="form-group">
                <label for="displayName" class="playful-label">اختر اسماً يظهر لأفراد منزلك:</label>
                <input id="displayName" type="text" @bind="displayName" @bind:event="oninput" @onkeydown="HandleKeyDown"
                       class="playful-input" placeholder="مثال: رامي، سارة، أحمد..." />
                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <span class="error-msg text-danger mt-2 d-block">⚠️ @error</span>
                }
            </div>

            <button class="primary-btn btn-playful" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(displayName)">
                يلا نبدأ! 🚀
            </button>
        }
    </div>
</div>

@code {
    private string displayName = "";
    private string error = "";
    private bool isChecking = true;
    private AuthUser? authUser;

    protected override async Task OnInitializedAsync()
    {
        authUser = await Auth.GetCurrentUserAsync();
        if (authUser is null || string.IsNullOrEmpty(authUser.Uid))
        {
            Nav.NavigateTo("/signin");
            return;
        }

        // If profile already exists (returning user), skip to main app
        var existing = await UserService.GetProfileAsync(authUser.Uid);
        if (existing is not null && !string.IsNullOrWhiteSpace(existing.DisplayName))
        {
            Nav.NavigateTo("/");
            return;
        }

        // Pre-fill display name from email if available
        if (!string.IsNullOrEmpty(authUser.Email))
            displayName = authUser.Email.Split('@')[0];

        isChecking = false;
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(displayName)) return;
        displayName = displayName.Trim();
        if (displayName.Length < 2)
        {
            error = "الاسم قصير جداً (حرفان على الأقل).";
            return;
        }

        try
        {
            error = "جارٍ الحفظ...";
            StateHasChanged();

            var newProfile = new UserProfile
            {
                Uid = authUser!.Uid,
                Email = authUser.Uid,
                DisplayName = displayName,
                AuthVerified = false
            };
            await UserService.CreateProfileAsync(newProfile);

            error = "";
            Nav.NavigateTo("/onboarding/cuisines");
        }
        catch (Exception ex)
        {
            error = $"حدث خطأ ما: {ex.Message}";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
