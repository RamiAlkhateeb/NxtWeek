@page "/onboarding/username"
@using MealPlanner.Shared.Services
@using MealPlanner.Shared.Models
@inject IJSRuntime JS
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app onboarding-container" dir="rtl">
    <div class="onboarding-card">
        <div class="logo">🍳</div>
        <h1>مخطط الوجبات الذكي</h1>
        <p class="subtitle">خطوتك الأولى نحو تنظيم وجباتك الأسبوعية بكل سهولة ومتعة.</p>
        
        <div class="form-group">
            <label for="username">أدخل اسم المستخدم الخاص بك</label>
            <input id="username" type="text" @bind="username" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="مثال: رامي، أحمد، سارة..." />
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <span class="error-msg">@error</span>
            }
        </div>

        <button class="primary-btn btn-animate" @onclick="SubmitUsername" disabled="@string.IsNullOrWhiteSpace(username)">
            متابعة ‹
        </button>
    </div>
</div>

@code {
    private string username = "";
    private string error = "";

    private async Task SubmitUsername()
    {
        if (string.IsNullOrWhiteSpace(username)) return;

        username = username.Trim();
        if (username.Length < 2)
        {
            error = "يجب أن يكون اسم المستخدم حرفين على الأقل.";
            return;
        }

        // Check/Create profile in Firebase
        var profile = await UserService.GetProfileAsync(username);
        if (profile is null)
        {
            profile = new UserProfile
            {
                Username = username
            };
            await UserService.CreateProfileAsync(profile);
        }

        // Save to local storage
        await JS.InvokeVoidAsync("localStorage.setItem", "username", username);

        // Redirect based on onboarding status
        if (profile.PreferredCuisines != null && profile.PreferredCuisines.Count > 0 && 
            profile.SelectedMealIds != null && profile.SelectedMealIds.Count > 0)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            Nav.NavigateTo("/onboarding/cuisines");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitUsername();
        }
    }
}
