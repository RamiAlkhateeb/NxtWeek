@page "/"
@using MealPlanner.Shared.Models
@using MealPlanner.Shared.Services
@inject IMealService MealService
@inject IMealCacheService CacheService
@inject IMealCatalogService CatalogService
@inject IUserService UserService
@inject ISuggestionService SuggestionService
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="app" dir="rtl">
    <div class="dashboard-header-container">
        <div class="user-greeting">
            <span>مرحباً، <strong>@username</strong> 👋</span>
            <button class="logout-btn" @onclick="ChangeUser">تغيير المستخدم</button>
        </div>
        <button class="add-meal-floating-btn" @onclick='() => Nav.NavigateTo("/edit/new")'>+ إضافة وجبة</button>
    </div>

    <div class="header">
        <div class="header-top">
            <h1>📅 مخطط الوجبات الأسبوعي</h1>
        </div>
        <p>@WeekRangeLabel</p>
    </div>

    @if (isLoading)
    {
        <p style="padding:16px; color:#777; text-align:center">جارِ التحميل...</p>
    }
    else if (weekMeals.Count == 0)
    {
        <p style="padding:16px; color:#777; text-align:center">لا توجد وجبات لهذا الأسبوع</p>
    } 
    else
    {
        <div class="week-header">
            <div class="week-label">وجبات الأسبوع</div>
            <div class="week-nav">
                <button @onclick="GoPreviousWeek">‹</button>
                <button @onclick="GoNextWeek">›</button>
            </div>
        </div>

        <div class="day-strip">
            @foreach (var meal in weekMeals)
            {
                <div class="day-pill @(meal.Date == selectedDate ? "active" : "")"
                     @onclick="() => SelectDay(meal.Date)">
                    <span class="day-name">@ShortDayName(meal.DayName)</span>
                    <span class="day-num">@meal.Date.Day</span>
                </div>
            }
        </div>

        @if (SelectedMeal is not null)
        {
            <div class="section-label">وجبة اليوم المختارة</div>
            <div class="meal-card highlight-card">
                <div class="meal-card-header">
                    <span class="meal-card-day">@SelectedMeal.DayName، @SelectedMeal.Date.ToString("d MMMM")</span>
                    <div style="display: flex; gap: 4px;">
                        @if (SelectedMeal.IsFavorite)
                        {
                            <span class="meal-card-badge favorite">⭐ مفضلة</span>
                        }
                        <span class="meal-card-badge">غداء</span>
                    </div>
                </div>
                <div class="meal-card-name" style="cursor:pointer; font-size:18px; margin-top:8px" @onclick="() => ViewDetails(SelectedMeal)">
                    @SelectedMeal.Name
                </div>
                
                @if (SelectedMeal.SideDishes != null && SelectedMeal.SideDishes.Count > 0)
                {
                    <div class="side-dishes-chips" style="margin-top: 8px;">
                        @foreach (var sd in SelectedMeal.SideDishes)
                        {
                            <span class="side-dish-chip">@sd</span>
                        }
                    </div>
                }

                <div class="meal-card-actions">
                    <button @onclick="() => EditRequested(SelectedMeal)">✏️ تعديل</button>
                    <button class="primary" @onclick="() => SuggestNew(SelectedMeal)">🔄 اقتراح جديد</button>
                </div>
            </div>
        }

        <div class="section-label" style="margin-top:16px">بقية الأسبوع</div>
        @foreach (var meal in weekMeals.Where(m => m.Date != selectedDate))
        {
            <div class="meal-card" style="opacity:0.85; cursor:pointer" @onclick="() => ViewDetails(meal)">
                <div class="meal-card-header">
                    <span class="meal-card-day">@meal.DayName، @meal.Date.ToString("d MMMM")</span>
                    <div style="display: flex; gap: 4px;">
                        @if (meal.IsFavorite)
                        {
                            <span class="meal-card-badge favorite">⭐ مفضلة</span>
                        }
                        <span class="meal-card-badge">غداء</span>
                    </div>
                </div>
                <div class="meal-card-name">@meal.Name</div>
                
                @if (meal.SideDishes != null && meal.SideDishes.Count > 0)
                {
                    <div class="side-dishes-chips" style="margin-top: 6px;">
                        @foreach (var sd in meal.SideDishes)
                        {
                            <span class="side-dish-chip" style="font-size: 11px; padding: 2px 8px; border-radius: 12px; background: #eee; margin-right: 4px;">@sd</span>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<Meal> weekMeals = new();
    private DateOnly selectedDate;
    private DateOnly currentWeekStart;
    private bool isLoading = true;
    private string username = "";

    private Meal? SelectedMeal => weekMeals.FirstOrDefault(m => m.Date == selectedDate);

    private string WeekRangeLabel =>
        weekMeals.Count > 0
            ? $"أسبوع {weekMeals.First().Date:d MMMM} – {weekMeals.Last().Date:d MMMM}"
            : "";

    protected override async Task OnInitializedAsync()
    {
        username = await JS.InvokeAsync<string>("localStorage.getItem", "username");
        if (string.IsNullOrWhiteSpace(username))
        {
            Nav.NavigateTo("/onboarding/username");
            return;
        }

        selectedDate = DateOnly.FromDateTime(DateTime.Today);
        currentWeekStart = StartOfWeek(selectedDate);
        await EnsureSeededAsync();
        await LoadWeekAsync(currentWeekStart);
    }

    private async Task EnsureSeededAsync()
    {
        var seeded = await MealService.IsSeededAsync();
        if (seeded) return;

        // Call the service's seed flow
        await MealService.SeedAsync(new List<Meal>());
    }

    private async Task LoadWeekAsync(DateOnly weekStart)
    {
        isLoading = true;

        // read-through cache: show cached data instantly
        var cached = await CacheService.GetCachedWeekAsync();
        if (cached is not null && cached.Count > 0 && StartOfWeek(cached.First().Date) == weekStart)
        {
            weekMeals = cached;
            isLoading = false;
            StateHasChanged();
        }

        var weekEnd = weekStart.AddDays(6);
        var fresh = await MealService.GetWeekAsync(weekStart, weekEnd);

        if (fresh.Count > 0)
        {
            weekMeals = fresh;
            await CacheService.SetCachedWeekAsync(fresh);
        }

        if (!weekMeals.Any(m => m.Date == selectedDate))
            selectedDate = weekMeals.Count > 0 ? weekMeals.First().Date : selectedDate;

        isLoading = false;
    }

    private DateOnly StartOfWeek(DateOnly date)
    {
        var diff = (7 + (int)date.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        return date.AddDays(-diff);
    }

    private void SelectDay(DateOnly date) => selectedDate = date;

    private async Task GoPreviousWeek()
    {
        var newStart = StartOfWeek(weekMeals.First().Date).AddDays(-7);
        selectedDate = newStart;
        await LoadWeekAsync(newStart);
    }

    private async Task GoNextWeek()
    {
        var newStart = StartOfWeek(weekMeals.First().Date).AddDays(7);
        selectedDate = newStart;
        await LoadWeekAsync(newStart);
    }

    private async Task SuggestNew(Meal meal)
    {
        var suggestions = await SuggestionService.GetSuggestionsAsync(username, weekMeals, count: 1);
        if (suggestions.Count == 0) return;

        var suggestedName = suggestions[0];
        
        // Find in catalog
        var catalog = await CatalogService.GetAllMealsAsync();
        var catItem = catalog.FirstOrDefault(c => c.Name.Equals(suggestedName, StringComparison.OrdinalIgnoreCase));
        
        meal.Name = suggestedName;
        if (catItem != null)
        {
            meal.MealId = catItem.Id;
            meal.Ingredients = catItem.Ingredients;
            meal.SideDishes = catItem.SideDishes;
            meal.Cuisine = catItem.Cuisine;
            meal.MealType = catItem.MealType;
        }
        else
        {
            meal.MealId = Guid.NewGuid().ToString("N");
            meal.Ingredients = new();
            meal.SideDishes = new();
        }

        await MealService.UpsertMealAsync(meal);
        await CacheService.SetCachedWeekAsync(weekMeals);
    }

    private void EditRequested(Meal meal)
    {
        Nav.NavigateTo($"/edit/{meal.Id}");
    }

    private void ViewDetails(Meal meal)
    {
        if (!string.IsNullOrEmpty(meal.MealId))
        {
            Nav.NavigateTo($"/meal/{meal.MealId}");
        }
    }

    private async Task ChangeUser()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "username");
        await CacheService.SetCachedWeekAsync(new List<Meal>());
        Nav.NavigateTo("/onboarding/username", forceLoad: true);
    }

    private string ShortDayName(string fullDayName) => fullDayName switch
    {
        "Sunday" => "أحد",
        "Monday" => "اثنين",
        "Tuesday" => "ثلاثاء",
        "Wednesday" => "أربعاء",
        "Thursday" => "خميس",
        "Friday" => "جمعة",
        "Saturday" => "سبت",
        _ => fullDayName
    };

    private class SeedDto
    {
        public string Id { get; set; } = "";
        public string Date { get; set; } = "";
        public string DayName { get; set; } = "";
        public string Name { get; set; } = "";
    }
}
