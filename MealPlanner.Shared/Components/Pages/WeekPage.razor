@page "/"
@using System.Globalization
@using MealPlanner.Shared.Models
@using MealPlanner.Shared.Services
@inject IMealService MealService
@inject IMealCacheService CacheService
@inject IMealCatalogService CatalogService
@inject ISuggestionService SuggestionService
@inject IAuthService Auth
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app app-content-wrapper" dir="rtl">
    <div class="dashboard-header-container">
        <div class="user-greeting">
            <span>مرحباً، <strong>@displayName</strong> 👋</span>
            <button class="logout-btn" @onclick="SignOut">تسجيل الخروج</button>
        </div>
        <button class="add-meal-btn-sm" title="إضافة وجبة" @onclick='() => Nav.NavigateTo("/edit/new")'>+</button>
    </div>

    <div class="week-page-header">
        <button class="month-link" @onclick='() => Nav.NavigateTo("/month")'>📅 عرض الشهر</button>
        <h1>مخططنا الأسبوعي</h1>
        <p>@WeekRangeLabel</p>
        <div class="week-nav week-nav-wide">
            <button @onclick="GoPreviousWeek">‹ الأسبوع السابق</button>
            <button @onclick="GoNextWeek">الأسبوع القادم ›</button>
        </div>
    </div>

    @if (isLoading)
    {
        <p class="loading-text">جارِ التحميل...</p>
    }
    else
    {
        <div class="week-cards">
            @foreach (var meal in weekMeals)
            {
                var isPast = meal.Date < DateOnly.FromDateTime(DateTime.Today);
                
                @if (string.IsNullOrWhiteSpace(meal.MealId))
                {
                    <button class="week-meal-card week-empty-card @(isPast ? "week-card-past" : "")" @onclick="() => EditRequested(meal)">
                        <span class="week-card-date">@DayDateLabel(meal.Date)</span>
                        <span class="week-empty-copy">لسه فاضي... يلا نضيف وجبة؟ 🍽️</span>
                    </button>
                }
                else
                {
                    <article class="week-meal-card week-empty-card @(isPast ? "week-card-past" : "")" @onclick="() => ViewDetails(meal)">
                        <div class="week-card-topline">
                            <span class="week-card-date">@DayDateLabel(meal.Date)</span>
                            @if (meal.IsFavorite)
                            {
                                <span class="meal-card-badge favorite">⭐ مفضلة</span>
                            }
                        </div>
                        <div class="week-card-name">@meal.Name</div>
                        <div class="meal-card-actions">
                            <button @onclick="() => EditRequested(meal)" @onclick:stopPropagation="true">✏️ تعديل</button>
                            <button class="primary" @onclick="() => SuggestNew(meal)" @onclick:stopPropagation="true">🔄 اقتراح جديد</button>
                        </div>
                    </article>
                }
            }
        </div>
    }
</div>

@code {
    private List<Meal> weekMeals = new();
    private DateOnly currentWeekStart;
    private bool isLoading = true;
    private string uid = "";
    private string displayName = "";
    private static readonly CultureInfo ArabicCulture = new("ar-EG");

    private string WeekRangeLabel => $"{DayDateLabel(currentWeekStart)} – {DayDateLabel(currentWeekStart.AddDays(6))}";

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("[WeekPage] OnInitializedAsync started.");
        var user = await Auth.GetCurrentUserAsync();
        Console.WriteLine($"[WeekPage] User returned: {(user == null ? "null" : user.Uid)}");
        if (user is null || string.IsNullOrEmpty(user.Uid))
        {
            Console.WriteLine("[WeekPage] No user session. Redirecting to /signin.");
            Nav.NavigateTo("/signin");
            return;
        }
        uid = user.Uid;

        Console.WriteLine($"[WeekPage] Loading profile for UID: {uid}...");
        var profile = await UserService.GetProfileAsync(uid);
        Console.WriteLine($"[WeekPage] Profile returned: {(profile == null ? "null" : profile.DisplayName)}");
        if (profile is null || string.IsNullOrWhiteSpace(profile.DisplayName))
        {
            Console.WriteLine("[WeekPage] Profile or DisplayName is missing. Redirecting to /onboarding/username.");
            Nav.NavigateTo("/onboarding/username");
            return;
        }
        displayName = profile.DisplayName;

        currentWeekStart = StartOfWeek(DateOnly.FromDateTime(DateTime.Today));
        await EnsureSeededAsync();
        await LoadWeekAsync(currentWeekStart);
    }

    private async Task EnsureSeededAsync()
    {
        if (!await MealService.IsSeededAsync())
            await MealService.SeedAsync(new List<Meal>());
    }

    private async Task LoadWeekAsync(DateOnly weekStart)
    {
        isLoading = true;
        currentWeekStart = weekStart;
        var fresh = await MealService.GetWeekAsync(weekStart, weekStart.AddDays(6));
        weekMeals = fresh;
        await CacheService.SetCachedWeekAsync(fresh);
        isLoading = false;
    }

    private static DateOnly StartOfWeek(DateOnly date) => date.AddDays(-(7 + (int)date.DayOfWeek - (int)DayOfWeek.Monday) % 7);

    private Task GoPreviousWeek() => LoadWeekAsync(currentWeekStart.AddDays(-7));
    private Task GoNextWeek() => LoadWeekAsync(currentWeekStart.AddDays(7));

    private async Task SuggestNew(Meal meal)
    {
        var suggestions = await SuggestionService.GetSuggestionsAsync(uid, weekMeals, count: 1);
        if (suggestions.Count == 0) return;

        var suggestedName = suggestions[0];
        var catalog = await CatalogService.GetAllMealsAsync();
        var item = catalog.FirstOrDefault(c => c.Name.Equals(suggestedName, StringComparison.OrdinalIgnoreCase));
        meal.Name = suggestedName;
        meal.MealId = item?.Id ?? "";
        meal.Ingredients = item?.Ingredients ?? new();
        meal.SideDishes = item?.SideDishes ?? new();
        meal.Cuisine = item?.Cuisine;
        meal.MealType = item?.MealType;
        await MealService.UpsertMealAsync(meal);
        await LoadWeekAsync(currentWeekStart);
    }

    private void EditRequested(Meal meal) => Nav.NavigateTo($"/edit/{meal.Date:yyyy-MM-dd}");
    private void ViewDetails(Meal meal) => Nav.NavigateTo($"/meal/{meal.MealId}");

    private async Task SignOut()
    {
        await Auth.SignOutAsync();
        UserService.ClearCachedHouseholdId();
        await CacheService.SetCachedWeekAsync(new List<Meal>());
        Nav.NavigateTo("/signin", forceLoad: true);
    }

    private static string DayDateLabel(DateOnly date) => date.ToString("dddd d MMMM", ArabicCulture);
}
