@page "/settings"
@using MealPlanner.Shared.Services
@using MealPlanner.Shared.Models
@inject IAuthService Auth
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app app-content-wrapper" dir="rtl">
    <div class="header">
        <h1>⚙️ الإعدادات</h1>
        <p>تخصيص التطبيق وربط الحسابات</p>
    </div>

    <div style="padding: 16px; display: flex; flex-direction: column; gap: 20px;">
        <!-- User Info Card -->
        <div class="card-playful" style="padding: 20px; display: flex; flex-direction: column; gap: 8px;">
            <div style="font-size: 14px; color: var(--color-text-secondary);">مرحباً،</div>
            <div style="font-size: 22px; font-weight: 900; color: var(--color-text-main);">@displayName 👋</div>
            <div style="font-size: 12px; color: var(--color-text-secondary);">@email</div>

            <div class="card-playful" style="margin-top: 12px; padding: 20px; display: flex; flex-direction: column; gap: 12px;">
                <h2 class="playful-title" style="font-size: 18px !important; margin: 0;">📂 استيراد سجل الوجبات</h2>
                <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0; line-height: 1.6;">
                    هل لديك سجل سابق في ملف JSON؟ يمكنك رفعه هنا لدمجه مع حسابك الحالي.
                </p>
                <button class="secondary-btn" style="margin-top: 4px;" @onclick='() => Nav.NavigateTo("/settings/import")'>
                    استيراد السجل
                </button>
            </div>

            <button class="primary-btn btn-playful" style="margin-top: 12px; background: #E74C3C !important;" @onclick="Logout">
                🚪 تسجيل الخروج
            </button>
        </div>

        <!-- Pending Link Requests Card -->
        @if (pendingRequests.Count > 0)
        {
            <div class="card-playful" style="padding: 20px; display: flex; flex-direction: column; gap: 12px;">
                <h2 class="playful-title" style="font-size: 18px !important; margin: 0;">📬 طلبات ربط واردة</h2>
                @foreach (var req in pendingRequests)
                {
                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 8px; border-bottom: 1px dashed var(--color-border); padding-bottom: 10px;">
                        <span style="font-size: 14px; font-weight: 700;">@req.DisplayName <span style="font-size: 11px; color: var(--color-text-secondary);">(@req.Uid)</span></span>
                        <div style="display: flex; gap: 6px;">
                            <button class="primary-btn btn-playful" style="padding: 6px 12px; font-size: 12px; background: #2ECC71 !important;" @onclick="() => AcceptRequest(req.Uid)">قبول ✅</button>
                            <button class="primary-btn btn-playful" style="padding: 6px 12px; font-size: 12px; background: #E74C3C !important;" @onclick="() => RejectRequest(req.Uid)">رفض ❌</button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Account Linking Card -->
        <div class="card-playful" style="padding: 20px; display: flex; flex-direction: column; gap: 16px;">
            <h2 class="playful-title" style="font-size: 18px !important; margin: 0;">🔗 ربط حسابك</h2>
            <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0; line-height: 1.6;">
                أدخل معرّف المستخدم (UID) أو البريد الإلكتروني للشخص الذي تريد الربط معه لمشاركة جدول الوجبات الأسبوعي.
            </p>

            <div class="form-group" style="margin: 0;">
                <label for="other-uid" class="playful-label" style="font-size: 13px !important;">معرّف المستخدم الآخر (UID):</label>
                <input id="other-uid" type="text" @bind="otherUid" @bind:event="oninput"
                       class="playful-input" style="width: 100%;" placeholder="أدخل معرّف المستخدم..." />
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert-playful" style="padding: 10px; font-size: 13px; text-align: center; background: @(isError ? "#FDEDEC" : "#E8F8F5"); color: @(isError ? "#C0392B" : "#117A65"); border-color: #2D3748;">
                    @statusMessage
                </div>
            }

            <button class="primary-btn btn-playful" @onclick="SendRequest" disabled="@(string.IsNullOrWhiteSpace(otherUid) || isSending)">
                @(isSending ? "جاري الإرسال..." : "إرسال طلب ربط 📲")
            </button>
        </div>

        <!-- Info Card -->
        <div class="card-playful" style="padding: 20px; background: var(--color-primary-light); display: flex; align-items: center; gap: 16px;">
            <div style="font-size: 40px;">💡</div>
            <div style="font-size: 12px; color: #2D3748; font-weight: 700; line-height: 1.6; text-align: right;">
                عند قبول الطلب، سيتم دمج جدول الوجبات وسيرث الحساب المقبول جدول الطرف الآخر لتصبحوا في منزل واحد! 🏡
            </div>
        </div>
    </div>
</div>

@code {
    private string uid = "";
    private string displayName = "";
    private string email = "";
    private string otherUid = "";
    private string statusMessage = "";
    private bool isError = false;
    private bool isSending = false;
    private List<PendingRequest> pendingRequests = new();

    private sealed record PendingRequest(string Uid, string DisplayName);

    protected override async Task OnInitializedAsync()
    {
        var user = await Auth.GetCurrentUserAsync();
        if (user is null || string.IsNullOrEmpty(user.Uid))
        {
            Nav.NavigateTo("/auth/signin");
            return;
        }
        uid = user.Uid;
        email = user.Email;

        var profile = await UserService.GetProfileAsync(uid);
        displayName = profile?.DisplayName ?? email;

        if (profile?.PendingLinkRequestUids != null)
        {
            foreach (var requesterUid in profile.PendingLinkRequestUids)
            {
                var requesterProfile = await UserService.GetProfileAsync(requesterUid);
                pendingRequests.Add(new PendingRequest(requesterUid, requesterProfile?.DisplayName ?? requesterUid));
            }
        }
    }

    private async Task SendRequest()
    {
        if (string.IsNullOrWhiteSpace(otherUid)) return;
        otherUid = otherUid.Trim();

        if (otherUid.Equals(uid, StringComparison.OrdinalIgnoreCase))
        {
            isError = true;
            statusMessage = "لا يمكنك إرسال طلب ربط لنفسك! 🧐";
            return;
        }

        isSending = true;
        statusMessage = "";
        StateHasChanged();

        try
        {
            var success = await UserService.SendLinkRequestAsync(uid, otherUid);
            if (success)
            {
                isError = false;
                statusMessage = "تم إرسال طلب الربط بنجاح! 🎉 بانتظار قبوله.";
                otherUid = "";
            }
            else
            {
                isError = true;
                statusMessage = "عذراً، لم نجد مستخدماً بهذا المعرّف 🧐 تحقق من المعرّف وحاول مجدداً.";
            }
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"حدث خطأ: {ex.Message}";
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task AcceptRequest(string requesterUid)
    {
        try
        {
            await UserService.AcceptLinkRequestAsync(uid, requesterUid);
            pendingRequests.RemoveAll(r => r.Uid == requesterUid);
            isError = false;
            statusMessage = "تم قبول الطلب ودمج الحسابات في منزل واحد! 🏡";
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"حدث خطأ: {ex.Message}";
        }
    }

    private async Task RejectRequest(string requesterUid)
    {
        try
        {
            await UserService.RejectLinkRequestAsync(uid, requesterUid);
            pendingRequests.RemoveAll(r => r.Uid == requesterUid);
        }
        catch (Exception ex)
        {
            isError = true;
            statusMessage = $"حدث خطأ: {ex.Message}";
        }
    }

    private async Task Logout()
    {
        await Auth.SignOutAsync();
        UserService.ClearCachedHouseholdId();
        Nav.NavigateTo("/auth/signin", forceLoad: true);
    }
}
