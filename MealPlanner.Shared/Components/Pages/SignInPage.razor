@page "/auth/signin"
@using MealPlanner.Shared.Services
@inject IAuthService Auth
@inject NavigationManager Nav

<div class="app onboarding-container" dir="rtl">
  <div class="onboarding-card card-playful">
    <h1 class="playful-title">تسجيل الدخول</h1>
    <p class="subtitle">سنرسل رابطاً آمناً إلى بريدك الإلكتروني.</p>
    <input class="playful-input" type="email" @bind="email" placeholder="name@example.com" />
    @if (!string.IsNullOrEmpty(message)) { <p class="error-msg">@message</p> }
    <button class="primary-btn btn-playful" @onclick="Send" disabled="@busy">إرسال رابط الدخول</button>
  </div>
</div>

@code {
  private string email = "";
  private string message = "";
  private bool busy;
  protected override async Task OnInitializedAsync()
  {
    Console.WriteLine("[SignInPage] OnInitializedAsync started. Attempting to complete sign-in...");
    // Same-browser flows use the session email hint; cross-device flows intentionally ask again.
    var user = await Auth.CompleteSignInAsync(email);
    Console.WriteLine($"[SignInPage] CompleteSignInAsync returned user: {(user == null ? "null" : user.Uid)}");
    if (user is { Uid.Length: > 0 })
    {
        Console.WriteLine("[SignInPage] Sign-in successful. Redirecting to /onboarding/username.");
        Nav.NavigateTo("/onboarding/username", true);
    }
    else if (user is not null)
    {
        Console.WriteLine("[SignInPage] Sign-in returned a placeholder/non-null user (probably email hint required).");
        message = "اكتب البريد الإلكتروني الذي استلم الرابط لإكمال تسجيل الدخول.";
    }
  }
  private async Task Send()
  {
    if (string.IsNullOrWhiteSpace(email)) return;
    busy = true;
    try { await Auth.SendSignInLinkAsync(email.Trim(), Nav.BaseUri + "auth/signin"); message = "تم إرسال الرابط. افتحه لإكمال تسجيل الدخول."; }
    catch (Exception ex) { message = ex.Message; }
    finally { busy = false; }
  }
}
