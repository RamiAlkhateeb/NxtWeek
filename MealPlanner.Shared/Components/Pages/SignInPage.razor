@page "/signin"
@using MealPlanner.Shared.Services
@using MealPlanner.Shared.Models
@inject IAuthService Auth
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app onboarding-container" dir="rtl">
    <div class="onboarding-card card-playful">
        <div class="logo-container">
            <span class="emoji-bounce">🍳</span>
            <span class="emoji-float emoji-delay-1">🥑</span>
            <span class="emoji-float emoji-delay-2">🍕</span>
            <span class="emoji-float emoji-delay-3">🍓</span>
        </div>
        <h1 class="playful-title">تسجيل الدخول السريع</h1>
        <p class="subtitle">أدخل بريدك الإلكتروني للبدء فوراً دون الحاجة لكلمة مرور.</p>

        <div class="form-group">
            <input class="playful-input" type="email" @bind="email" @bind:event="oninput" @onkeydown="HandleKeyDown" placeholder="name@example.com" disabled="@isProcessing" />
            @if (!string.IsNullOrEmpty(error))
            {
                <span class="error-msg text-danger mt-2 d-block">⚠️ @error</span>
            }
        </div>

        <button class="primary-btn btn-playful" @onclick="Submit" disabled="@(string.IsNullOrWhiteSpace(email) || isProcessing)">
            @if (isProcessing)
            {
                <span>جاري التحميل... ⏳</span>
            }
            else
            {
                <span>متابعة 🚀</span>
            }
        </button>
    </div>
</div>

@code {
    private string email = "";
    private string error = "";
    private bool isProcessing = false;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;
        email = email.Trim();

        if (!IsValidEmail(email))
        {
            error = "الرجاء إدخال بريد إلكتروني صحيح.";
            return;
        }

        isProcessing = true;
        error = "";
        StateHasChanged();

        try
        {
            // Sign in locally to get current user credentials
            var user = await Auth.SignInAsync(email);
            var sanitized = user.Uid;

            // Check database for existing profile
            var profile = await UserService.GetProfileAsync(sanitized);
            if (profile is not null && !string.IsNullOrWhiteSpace(profile.DisplayName))
            {
                // Returning user with a setup profile: go to dashboard
                Nav.NavigateTo("/");
            }
            else
            {
                // New user: go to username selection onboarding step
                Nav.NavigateTo("/onboarding/username");
            }
        }
        catch (Exception ex)
        {
            error = $"حدث خطأ أثناء تسجيل الدخول: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    private bool IsValidEmail(string emailStr)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(emailStr);
            return addr.Address == emailStr && emailStr.Contains(".");
        }
        catch
        {
            return false;
        }
    }
}
