@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="app-shell">
    @Body
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.Uri;
        var relative = Nav.ToBaseRelativePath(uri);
        
        // Skip checking if we are already on onboarding pages
        if (relative.StartsWith("onboarding", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            var username = await JS.InvokeAsync<string?>("localStorage.getItem", "username");
            if (string.IsNullOrWhiteSpace(username))
            {
                Nav.NavigateTo("/onboarding/username");
            }
        }
        catch
        {
            // Safe fallback
        }
    }
}
