@inherits LayoutComponentBase
@implements IDisposable
@inject IAuthService Auth
@inject IUserService UserService
@inject NavigationManager Nav

<div class="app-shell" style="flex-direction: column; align-items: center;">
    @if (pendingRequests.Count > 0)
    {
        @foreach (var req in pendingRequests.Where(x => !dismissedRequests.Contains(x.Uid)).ToList())
        {
            <div class="link-request-banner" style="width: 100%; max-width: 600px; box-sizing: border-box;">
                <div style="display: flex; justify-content: space-between; align-items: start; gap: 8px;">
                    <span>🔔 طلب ربط من <strong>@req.DisplayName</strong> — قبول / رفض</span>
                    <button class="btn-reject" style="padding: 4px 10px; font-size: 12px; border-width: 2px;" @onclick="() => DismissRequest(req.Uid)">إغلاق</button>
                </div>
                <div class="link-request-actions">
                    <button class="btn-accept" @onclick="() => AcceptRequest(req.Uid)">قبول ✅</button>
                    <button class="btn-reject" @onclick="() => RejectRequest(req.Uid)">رفض ❌</button>
                </div>
            </div>
        }
    }

    <div style="width: 100%; display: flex; justify-content: center; flex: 1;">
        @Body
    </div>

    <MealPlanner.Shared.Components.BottomNav />
</div>

@code {
    private sealed record PendingRequest(string Uid, string DisplayName);

    private List<PendingRequest> pendingRequests = new();
    private HashSet<string> dismissedRequests = new(StringComparer.OrdinalIgnoreCase);
    private string currentUid = "";

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await CheckRequestsAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await CheckRequestsAsync();
        StateHasChanged();
    }

    private async Task CheckRequestsAsync()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        Console.WriteLine($"[MainLayout] CheckRequestsAsync called for path: {relative}");

        // Don't check on auth/onboarding pages — user may not be signed in yet
        if (relative.StartsWith("onboarding", StringComparison.OrdinalIgnoreCase) ||
            relative.StartsWith("auth", StringComparison.OrdinalIgnoreCase))
        {
            Console.WriteLine("[MainLayout] On onboarding/auth page. Clearing pending requests and returning.");
            pendingRequests.Clear();
            return;
        }

        try
        {
            Console.WriteLine("[MainLayout] Fetching current user...");
            var user = await Auth.GetCurrentUserAsync();
            Console.WriteLine($"[MainLayout] Current user is: {(user == null ? "null" : user.Uid)}");
            if (user is null || string.IsNullOrEmpty(user.Uid))
            {
                pendingRequests.Clear();
                return;
            }
            currentUid = user.Uid;

            Console.WriteLine($"[MainLayout] Fetching profile for UID: {currentUid}...");
            var profile = await UserService.GetProfileAsync(currentUid);
            Console.WriteLine($"[MainLayout] Profile loaded: {(profile == null ? "null" : profile.DisplayName)}");
            if (profile?.PendingLinkRequestUids is { Count: > 0 } uids)
            {
                var requests = new List<PendingRequest>();
                foreach (var uid in uids)
                {
                    var p = await UserService.GetProfileAsync(uid);
                    requests.Add(new PendingRequest(uid, p?.DisplayName ?? uid));
                }
                pendingRequests = requests;
            }
            else
            {
                pendingRequests.Clear();
            }
        }
        catch
        {
            // Safe fallback — don't crash the layout
        }
    }

    private async Task AcceptRequest(string requesterUid)
    {
        if (string.IsNullOrEmpty(currentUid)) return;
        await UserService.AcceptLinkRequestAsync(currentUid, requesterUid);
        pendingRequests.RemoveAll(r => r.Uid == requesterUid);
        dismissedRequests.Remove(requesterUid);
        StateHasChanged();
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task RejectRequest(string requesterUid)
    {
        if (string.IsNullOrEmpty(currentUid)) return;
        await UserService.RejectLinkRequestAsync(currentUid, requesterUid);
        pendingRequests.RemoveAll(r => r.Uid == requesterUid);
        dismissedRequests.Remove(requesterUid);
        StateHasChanged();
    }

    private void DismissRequest(string requesterUid)
    {
        dismissedRequests.Add(requesterUid);
        pendingRequests.RemoveAll(r => r.Uid == requesterUid);
        StateHasChanged();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
